PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/travel_requests

# Google OAuth (Public App)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Auth Mode
# Use google-groups in production once the service account has domain-wide delegation
# and ADMIN_EMAIL is a valid delegated admin. Use email-allowlist as a recovery mode.
AUTH_MODE=email-allowlist
ALLOWED_MANAGER_EMAILS=admin@example.com
ALLOWED_EMPLOYEE_EMAILS=user1@example.com,user2@example.com
ALLOWED_EMAIL_DOMAIN=ssvlabs.io
ADMIN_OVERRIDE_EMAILS=yoav@example.com,alon@example.com,keren@example.com
MANAGER_OVERRIDE_EMAILS=manager1@example.com,manager2@example.com
COORDINATOR_EMAILS=tamar@example.com

# Google Workspace Security (Admin SDK)
ADMIN_EMAIL=admin@example.com
ADMIN_GROUP_EMAIL=travel-app-admins@example.com
USER_GROUP_EMAIL=travel-app-users@example.com

# Email Notifications (Gmail API)
GOOGLE_REFRESH_TOKEN=
APPROVER_EMAIL=approver@example.com
NOTIFICATION_SENDER_NAME=SSV Labs Travel Desk
NOTIFICATION_FROM_EMAIL=travel@example.com
PRIMARY_APPROVER_EMAILS=yoav@example.com
NOTIFY_ALL_EMAILS=tamar@example.com

# Frontend URL for redirects and email links
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ALT=http://127.0.0.1:5173

# Session Security
JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=travel_requests_session
SESSION_TTL_SECONDS=28800
COOKIE_SECURE=false
